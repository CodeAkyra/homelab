#L3 int (SVIs)
en
  conf t
    int vlan10
      ip add 10.10.10.1 255.255.255.0
      no shut
      exit
    int vlan20
      ip add 10.20.20.1 255.255.255.0
      no shut
      exit
    int vlan99
      ip add 10.99.99.1 255.255.255.0
      no shut
      exit
    ip routing
